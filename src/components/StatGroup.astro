---
// Per-repo stats (downloads + GitHub stars) in a single horizontal pill.
interface Props {
  downloads?: number | null;
  stars?: number | null;
}
const { downloads, stars } = Astro.props;

// 12345 -> "12.3k"
const fmt = (n: number): string =>
  n >= 1e6
    ? (n / 1e6).toFixed(1).replace(/\.0$/, '') + 'M'
    : n >= 1e3
      ? (n / 1e3).toFixed(1).replace(/\.0$/, '') + 'k'
      : String(n);
---

{
  (downloads || stars) && (
    <span class="ml-2 inline-flex items-center gap-2 rounded-full bg-secondary/10 dark:bg-secondary/15 px-2.5 py-1 text-xs font-semibold text-secondary dark:text-secondary-200 align-middle">
      {downloads ? (
        <span title="Downloads on PyPI and conda-forge" class="inline-flex items-center gap-1">
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 3v12m0 0l-4-4m4 4l4-4M4 17v2a2 2 0 002 2h12a2 2 0 002-2v-2" />
          </svg>
          {fmt(downloads)}
        </span>
      ) : null}
      {downloads && stars ? <span class="w-px self-stretch bg-secondary/25 dark:bg-secondary/30" aria-hidden="true" /> : null}
      {stars ? (
        <span title="GitHub stars" class="inline-flex items-center gap-1">
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
          </svg>
          {stars}
        </span>
      ) : null}
    </span>
  )
}
