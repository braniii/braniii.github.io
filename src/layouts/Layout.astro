---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Personal page of Daniel Nagel (@braniii) — publications and open source software."
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Daniel Nagel</title>
  </head>

  <body class="bg-white min-h-screen sm:py-6">
    <div class="flex w-full min-h-screen items-start sm:items-center justify-center">
      <div class="sm:pt-60">
        <div class="w-full max-w-2xl px-6 mx-auto my-auto h-auto">
          <Header />
          <slot />
          <Footer />
        </div>
      </div>
    </div>
  </body>
</html>
