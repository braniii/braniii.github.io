---
import Layout from '../layouts/Layout.astro';
import { articles, software } from '../data/index.json';
---

<Layout>
  <!-- About -->
  <div class="mt-2 sm:mt-0 mb-6 sm:mb-12">
    <div>
      <div class="text-base text-slate-600 text-justify italic">
        <span class="inline-block"> Hi there👋 </span>
      </div>
    </div>
  </div>

  <!-- Publications / Software tabs -->
  <div class="my-6">
    <div class="flex my-6 justify-center gap-8" role="tablist" aria-label="Publications and software">
      <button
        type="button"
        role="tab"
        id="tab-publications"
        aria-controls="panel-publications"
        aria-selected="true"
        class="text-xl font-medium uppercase cursor-pointer pb-1 border-b-2 transition-colors duration-300 border-transparent text-slate-400 not-aria-selected:hover:text-slate-600 aria-selected:border-greenish aria-selected:text-black"
      >
        publications 📚
      </button>
      <button
        type="button"
        role="tab"
        id="tab-software"
        aria-controls="panel-software"
        aria-selected="false"
        class="text-xl font-medium uppercase cursor-pointer pb-1 border-b-2 transition-colors duration-300 border-transparent text-slate-400 not-aria-selected:hover:text-slate-600 aria-selected:border-greenish aria-selected:text-black"
      >
        software 💿
      </button>
    </div>

    <section id="panel-publications" role="tabpanel" aria-labelledby="tab-publications">
      <div class="text-base text-slate-600 text-center italic">
        <span class="text-base"
          >You can also check out my <a
            href="https://scholar.google.com/citations?user=3Pz_4wwAAAAJ"
            target="_blank"><span class="text-greenish">google scholar</span></a
          > for an up-to-date list.</span
        >
      </div>
      <div>
        {
          articles.map((at) => (
          <div class="px-4 py-3 my-3 border-l-4 border-greenish rounded-sm shadow-md hover:shadow-inner bg-slate-100 transition-shadow duration-300 rounded-r-xl">
            <span class="text-sm">
              {at.authors},{' '}
              <a href={at.url} target="_blank">
                <span class="text-greenish italic">{at.title}</span>
              </a>
              , {at.journal}, {at.year}
              </span>
            </div>
          ))
        }
      </div>
    </section>

    <section id="panel-software" role="tabpanel" aria-labelledby="tab-software" hidden>
      <div class="text-base text-slate-600 text-center italic">
        <span class="text-base"
          >The following list is not complete. Please refer to my Github/Gitlab pages for more
          details.</span
        >
      </div>
      <div>
        {
          software.map((sw) => (
          <div class="flex flex-col px-4 py-3 my-3 border-l-4 border-greenish rounded-sm shadow-md hover:shadow-inner bg-slate-100 transition-shadow duration-300 rounded-r-xl">
            <div class="flex mb-2">
              <a class="flex items-center" href={sw.url} target="_blank">
                <span class="text-sm">{sw.title}</span>
                <div class="w-3.5 h-3.5 ml-1.5 text-greenish">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                    <path d="M11 3a1 1 0 100 2h2.586l-6.293 6.293a1 1 0 101.414 1.414L15 6.414V9a1 1 0 102 0V4a1 1 0 00-1-1h-5z" />
                    <path d="M5 5a2 2 0 00-2 2v8a2 2 0 002 2h8a2 2 0 002-2v-3a1 1 0 10-2 0v3H5V7h3a1 1 0 000-2H5z" />
                  </svg>
                </div>
                <span class="text-sm text-slate-600 ml-1.5 italic">#{sw.contribution}</span>
              </a>
            </div>
            <div class="flex text-sm text-slate-600">
              <span>{sw.description}</span>
            </div>
            <div class="flex text-sm text-greenish">
              <span>{sw.hashtag}</span>
            </div>
          </div>
        ))
      }
      </div>
    </section>
  </div>

  <!-- With JS disabled, show both panels instead of an unreachable tab -->
  <noscript>
    <style>
      [role='tabpanel'][hidden] {
        display: block;
      }
      [role='tab'] {
        border-color: var(--color-greenish);
        color: var(--color-black);
      }
    </style>
  </noscript>
</Layout>

<script>
  const tabs = [...document.querySelectorAll<HTMLButtonElement>('[role="tab"]')];

  const activate = (tab: HTMLButtonElement, updateHash = true) => {
    for (const t of tabs) {
      const selected = t === tab;
      t.setAttribute('aria-selected', String(selected));
      const panel = document.getElementById(t.getAttribute('aria-controls')!);
      if (panel) panel.hidden = !selected;
    }
    if (updateHash) {
      history.replaceState(null, '', '#' + tab.id.replace('tab-', ''));
    }
  };

  tabs.forEach((tab, i) => {
    tab.addEventListener('click', () => activate(tab));
    tab.addEventListener('keydown', (event) => {
      if (event.key !== 'ArrowRight' && event.key !== 'ArrowLeft') return;
      const step = event.key === 'ArrowRight' ? 1 : tabs.length - 1;
      const next = tabs[(i + step) % tabs.length];
      next.focus();
      activate(next);
    });
  });

  // Support deep links like /#software
  const initial = document.getElementById('tab-' + location.hash.slice(1));
  if (initial) activate(initial as HTMLButtonElement, false);
</script>
